# Servidor
NODE_ENV=production
PORT=3000

# PostgreSQL (Railway lo genera automáticamente)
DATABASE_URL=postgresql://user:password@host:port/carguill_db

# Kapso
KAPSO_WEBHOOK_SECRET=tu_secret_key_de_webhook
KAPSO_API_KEY=tu_api_key_kapso
KAPSO_PHONE_NUMBER_ID=tu_phone_number_id

# Autenticación — configura estas 3 en Railway
# JWT_SECRET es OBLIGATORIO en producción: sin él la app no arranca (evita firmar
# tokens con un secreto conocido). En desarrollo se genera uno temporal por proceso.
JWT_SECRET=tu_jwt_secret_super_seguro_cambiar_en_produccion
ADMIN_EMAIL=admin@carguill.com
ADMIN_PASSWORD=tu_password_seguro

# CORS — lista de orígenes permitidos separados por coma (ej. el dominio del panel).
# Si se deja vacío, se permite "*" pero SIN credenciales cross-origin.
ALLOWED_ORIGINS=https://panel.tudominio.com

# Debounce del bot en segundos (agrupa ráfagas de mensajes antes de responder)
BOT_DEBOUNCE_SEG=4

# Logs
LOG_LEVEL=info
